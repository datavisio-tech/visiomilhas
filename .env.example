# .env.example for VisioMilhas
# Copy this file to .env.local for local development.
# For production, real values must come from GitHub Environment "production" secrets
# and be rendered into .env.production by the deploy workflow.
# Never commit real credentials, tokens, private keys, database URLs or production secrets.
#
# Production domain: https://visiomilhas.visiochat.cloud

# App
APP_NAME=VisioMilhas
APP_URL=https://example.visiochat.cloud
NEXT_PUBLIC_APP_URL=https://example.visiochat.cloud
NODE_ENV=development

# Feature flags
# When true, routes/actions will use the FIFO movements engine (`movements.use-cases`).
# Default: false. Values accepted as true: "1", "true", "on" (trim + case-insensitive).
# Production initial rollout must keep this disabled until staging QA is approved.
USE_FIFO_MOVEMENTS_ENGINE=0

# PostgreSQL base variables
POSTGRES_HOST=example-postgres-host
POSTGRES_PORT=5432
POSTGRES_USER=example_postgres_user
POSTGRES_PASSWORD=example_postgres_password
POSTGRES_DB=example_default_database
SAAS_DB=controle_adm_saas_datavisio
APP_DB=visiomilhas_app

# PostgreSQL composed URLs
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
ADM_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${SAAS_DB}
APP_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${APP_DB}

# MongoDB base variables
MONGODB_SERVER_IP=example-mongodb-host
MONGODB_USER=example_mongodb_user
MONGODB_USER_PASSWORD=example_mongodb_password
MONGODB_DATABASE=datavisio

# MongoDB composed URI
MONGODB_URI=mongodb://${MONGODB_USER}:${MONGODB_USER_PASSWORD}@${MONGODB_SERVER_IP}/${MONGODB_DATABASE}

# Optional operational variables
# POSTGRES_ADMIN_DATABASE_URL is used by db:create-databases and admin scripts.
# STAGING_DATABASE_NAME and TEST_DATABASE_NAME can be used by validation scripts.
POSTGRES_ADMIN_DATABASE_URL=postgresql://example_user:example_password@example-host:5432/postgres
STAGING_DATABASE_NAME=staging_db
TEST_DATABASE_NAME=test_db

# Production notes
# Production domain: https://visiomilhas.visiochat.cloud
# In production, NODE_ENV must be production.
# In the initial production rollout, USE_FIFO_MOVEMENTS_ENGINE must remain 0.
# Real values must be stored in GitHub Environment production secrets and rendered into .env.production by the deploy workflow.
