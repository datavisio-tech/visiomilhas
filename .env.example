APP_NAME=VisioMilhas
APP_URL=https://visiomilhas.visiochat.cloud
NEXT_PUBLIC_APP_URL=https://visiomilhas.visiochat.cloud

# PostgreSQL base connection parts
POSTGRES_HOST=your-postgres-host
POSTGRES_PORT=5432
POSTGRES_USER=your-postgres-user
POSTGRES_PASSWORD=your-postgres-password

# Database names
POSTGRES_DB=visiomilhas_db
SAAS_DB=controle_adm_saas_datavisio
APP_DB=visiomilhas_app_db
DATABASE_STAGING=staging_db
DATABASE_TEST=test_db

# PostgreSQL URLs
# Default database URL used by local/dev flows when applicable.
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Shared administrative SaaS database used by DataVisio.
ADM_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${SAAS_DB}

# Application-specific database for VisioMilhas.
APP_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${APP_DB}

# Isolated staging database URL. Never point this to production.
STAGING_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${DATABASE_STAGING}

# Isolated test/integration database URL. Never point this to production.
TEST_DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${DATABASE_TEST}

# Feature flags
# When true, routes/actions will use the FIFO movements engine (`movements.use-cases`).
# Default: false. Values accepted: "1", "true", "on".
USE_FIFO_MOVEMENTS_ENGINE=0

# Optional: admin connection (must point to an existing DB like 'postgres' or 'template1')
# Required only to create the databases when they don't exist.
POSTGRES_ADMIN_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/postgres

AUTH_SECRET=CHANGE_ME
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_CHANGE_ME
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

SSH_HOST=CHANGE_ME
SSH_USER=CHANGE_ME
SSH_PRIVATE_KEY=CHANGE_ME
APP_ENV=production

# MongoDB
MONGODB_SERVER_IP=your-mongodb-host
MONGODB_USER=your-mongodb-user
MONGODB_USER_PASSWORD=your-mongodb-password
MONGODB_DATABASE=visiomilhas_mongo
MONGODB_URI=mongodb://${MONGODB_USER}:${MONGODB_USER_PASSWORD}@${MONGODB_SERVER_IP}/${MONGODB_DATABASE}

# Optional: dedicated staging and test DB variables
# Use `STAGING_DATABASE_URL` to point CI/staging integration tests to an isolated DB.
# Use `TEST_DATABASE_URL` for local test runners if you need a separate test DB.
# Never put real credentials here; use secrets in CI or `.env.local` on the host.
